#!/usr/bin/env bash
set -u

usage() {
  cat <<'USAGE'
Usage:
  tools/helper-only-brief [--harness codex|claude] [--mode explore|implement]
    [--authority read-only|report|edit] [--cwd PATH] [--task TEXT]
    [--lane LANE] [--source PATH_OR_COMMAND]... [--json]
  tools/helper-only-brief --self-test
USAGE
}

fail() {
  printf 'helper-only-brief: %s\n' "$1" >&2
  exit 2
}

contains_required_sections() {
  case "$1" in
    *"# Helper-Only Brief"*\
*"## Lead Constraints"*\
*"## Helper Brief"*\
*"## Required Startup Reads"*\
*"## Forbidden Paths and Actions"*\
*"## Dirty State"*\
*"## Return Schema"*\
*"## Source Manifest"*) return 0 ;;
    *) return 1 ;;
  esac
}

self_test() {
  output="$("$0" --harness codex --mode explore --authority read-only --cwd "$PWD" --task "self test" --source "AGENTS.md" 2>&1)" || {
    printf '%s\n' "$output" >&2
    exit 1
  }
  contains_required_sections "$output" || {
    printf 'self-test failed: missing required sections\n' >&2
    exit 1
  }
  case "$output" in
    *"Harness: codex"*\
*"Mode: explore"*\
*"Authority: read-only"*\
*"AGENTS.md"*) ;;
    *)
      printf 'self-test failed: missing expected values\n' >&2
      exit 1
      ;;
  esac
  printf 'helper-only-brief self-test ok\n'
}

harness="codex"
mode="explore"
authority="read-only"
cwd="$PWD"
task=""
lane=""
json="false"
sources=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --self-test)
      self_test
      exit 0
      ;;
    --harness)
      [ "$#" -ge 2 ] || fail "--harness requires codex or claude"
      harness="$2"
      shift 2
      ;;
    --mode)
      [ "$#" -ge 2 ] || fail "--mode requires explore or implement"
      mode="$2"
      shift 2
      ;;
    --authority)
      [ "$#" -ge 2 ] || fail "--authority requires read-only, report, or edit"
      authority="$2"
      shift 2
      ;;
    --cwd)
      [ "$#" -ge 2 ] || fail "--cwd requires a path"
      cwd="$2"
      shift 2
      ;;
    --task)
      [ "$#" -ge 2 ] || fail "--task requires text"
      task="$2"
      shift 2
      ;;
    --lane)
      [ "$#" -ge 2 ] || fail "--lane requires a lane name"
      lane="$2"
      shift 2
      ;;
    --source)
      [ "$#" -ge 2 ] || fail "--source requires a path or command"
      sources+=("$2")
      shift 2
      ;;
    --json)
      json="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "unknown argument: $1"
      ;;
  esac
done

case "$harness" in
  codex|claude) ;;
  *) fail "--harness must be codex or claude" ;;
esac

case "$mode" in
  explore|implement) ;;
  *) fail "--mode must be explore or implement" ;;
esac

case "$authority" in
  read-only|report|edit) ;;
  *) fail "--authority must be read-only, report, or edit" ;;
esac

if [ "$json" = "true" ]; then
  fail "JSON output is intentionally unsupported; use deterministic Markdown output"
fi

if [ -z "$task" ]; then
  task="(none supplied)"
fi

if [ -z "$lane" ]; then
  lane="(unspecified)"
fi

if command -v jj >/dev/null 2>&1; then
  if [ -d "$cwd" ]; then
    dirty_state="$(cd "$cwd" && jj st 2>&1)"
    dirty_status=$?
    if [ "$dirty_status" -ne 0 ]; then
      dirty_state="jj st failed: $dirty_state"
    fi
  else
    dirty_state="cwd does not exist: $cwd"
  fi
else
  dirty_state="jj unavailable; dirty state not collected"
fi

cat <<EOF
# Helper-Only Brief

Harness: $harness
Mode: $mode
Authority: $authority
Working directory: $cwd
Lane: $lane
Task: $task

## Lead Constraints

- The lead is in main-thread no-reading mode.
- The lead may read this generated brief and the helper return.
- The lead must not perform broad workspace inspection, report triage, source exploration, or multi-file context gathering.
- The lead must dispatch meaningful reading and command output collection to the helper.
- The lead must ask the psyche before expanding into private scope, changing authority, or choosing across a real judgment fork.

## Helper Brief

You are the helper for a helper-only workflow. Carry the reading context for the lead.

- Work from the directory listed above.
- Follow the authority exactly: read-only means no edits, report means write only the requested report lane, edit means scoped implementation is allowed.
- Perform the startup reads and source reads yourself.
- Use deterministic observations from files and commands; do not classify or infer intent with AI.
- Keep private information out of public reports, commits, and chat.

## Required Startup Reads

- AGENTS.md in the working directory.
- skills/skills.nota in the working directory.
- Any skills selected from skills/skills.nota by the task, discipline, tool, repo, and risk.
- Every source listed in the Source Manifest.

## Forbidden Paths and Actions

- Do not inspect private-repos/ unless the brief contains explicit user authorization for that private scope.
- Do not search /nix/store.
- Do not use raw git. Use jj for version-control status or commits when authority permits.
- Do not exceed authority: no edits under read-only, no files outside the report lane under report, no unrelated refactors under edit.
- Do not revert existing dirty edits unless the psyche explicitly requested that operation.
- Do not infer durable psyche intent when unclear; return the question instead.

## Dirty State

\`\`\`text
$dirty_state
\`\`\`

## Return Schema

Return exactly these sections:

1. Files read.
2. Files changed or created.
3. Commands run and outcomes.
4. Findings or implementation summary.
5. Blockers or open questions.
6. Dirty-state changes observed.
7. Next concrete action.

## Source Manifest

EOF

if [ "${#sources[@]}" -eq 0 ]; then
  printf '%s\n' '- (none supplied)'
else
  for source in "${sources[@]}"; do
    printf -- '- %s\n' "$source"
  done
fi
