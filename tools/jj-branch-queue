#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage:
  tools/jj-branch-queue <repo>... -- <pattern>...

Reports matching jj bookmarks in each repo, whether each bookmark is
integrated into main, and commits ahead of main.

Patterns are extended regular expressions matched against bookmark names.
If no pattern is provided after --, all bookmarks are reported.
USAGE
}

if [ "$#" -eq 0 ]; then
  usage
  exit 2
fi

repos=()
patterns=()
seen_separator=false

for argument in "$@"; do
  if [ "$argument" = "--" ]; then
    seen_separator=true
    continue
  fi

  if [ "$seen_separator" = true ]; then
    patterns+=("$argument")
  else
    repos+=("$argument")
  fi
done

if [ "$seen_separator" = false ] || [ "${#repos[@]}" -eq 0 ]; then
  usage
  exit 2
fi

bookmark_matches_patterns() {
  local bookmark="$1"
  local pattern

  if [ "${#patterns[@]}" -eq 0 ]; then
    return 0
  fi

  for pattern in "${patterns[@]}"; do
    if grep -Eq -- "$pattern" <<<"$bookmark"; then
      return 0
    fi
  done

  return 1
}

repo_name() {
  local repo="$1"
  basename "$repo"
}

list_bookmarks() {
  jj bookmark list --all \
    | sed -n 's/^\([^[:space:]][^:]*\):.*/\1/p'
}

commit_lines_ahead_of_main() {
  local bookmark="$1"
  jj log \
    -r "ancestors($bookmark) ~ ancestors(main)" \
    --no-graph \
    -T 'commit_id.short() ++ " " ++ description.first_line() ++ "\n"'
}

for repo in "${repos[@]}"; do
  printf 'repo %s (%s)\n' "$(repo_name "$repo")" "$repo"

  if [ ! -d "$repo" ]; then
    printf '  error: path does not exist or is not a directory\n\n'
    continue
  fi

  if [ ! -d "$repo/.jj" ]; then
    printf '  error: not a colocated jj repository\n\n'
    continue
  fi

  matched=false

  while IFS= read -r bookmark; do
    if ! bookmark_matches_patterns "$bookmark"; then
      continue
    fi

    matched=true
    ahead_lines="$(cd "$repo" && commit_lines_ahead_of_main "$bookmark")"

    if [ -z "$ahead_lines" ]; then
      printf '  %s integrated yes\n' "$bookmark"
    else
      printf '  %s integrated no\n' "$bookmark"
      while IFS= read -r ahead_line; do
        [ -n "$ahead_line" ] || continue
        printf '    %s\n' "$ahead_line"
      done <<<"$ahead_lines"
    fi
  done < <(cd "$repo" && list_bookmarks)

  if [ "$matched" = false ]; then
    printf '  no matching bookmarks\n'
  fi

  printf '\n'
done
