#!/usr/bin/env bash
set -euo pipefail

workspace="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

ROLES=(operator operator-assistant second-operator-assistant designer designer-assistant second-designer-assistant system-specialist system-assistant second-system-assistant poet poet-assistant)

usage() {
  cat <<'EOF'
Usage:
  tools/orchestrate claim <role> <scope> [more-scopes] -- <reason>
  tools/orchestrate release <role>
  tools/orchestrate status

Roles: operator, operator-assistant, second-operator-assistant, designer, designer-assistant, second-designer-assistant, system-specialist, system-assistant, second-system-assistant, poet, poet-assistant

Scopes: each <scope> is either
  - an absolute path:    /home/li/primary/skills/foo.md
  - a task lock:         '[primary-f99]'      (quote in shell — `[` is a glob char)

Lock files (<role>.lock) are plain text. Empty file means idle.
Each line is one scope, optionally followed by `# <reason>`:
  /home/li/primary/skills/foo.md # syncing claim docs
  [primary-f99] # chroma nota-codec migration
EOF
}

valid_role() {
  local candidate="$1"
  local role
  for role in "${ROLES[@]}"; do
    [ "$role" = "$candidate" ] && return 0
  done
  return 1
}

lock_path() {
  valid_role "$1" || { printf 'unknown role: %s\n' "$1" >&2; exit 64; }
  printf '%s/orchestrate/%s.lock\n' "$workspace" "$1"
}

peer_roles() {
  local role="$1"
  local other
  for other in "${ROLES[@]}"; do
    [ "$other" != "$role" ] && printf '%s\n' "$other"
  done
}

normal_path() {
  case "$1" in
    /*) realpath -m "$1" ;;
    *) realpath -m "$PWD/$1" ;;
  esac
}

# A task-lock scope is a bracketed token like `[primary-f99]`.
# Path scopes are everything else; they get path-normalized.
is_task_lock() {
  [[ "$1" =~ ^\[.+\]$ ]]
}

normalize_scope() {
  if is_task_lock "$1"; then
    printf '%s\n' "$1"
  else
    normal_path "$1"
  fi
}

write_lock() {
  local role="$1"
  local reason="${2:-}"
  shift 2 || true
  local lock
  lock="$(lock_path "$role")"

  : > "$lock"
  local scope
  for scope in "$@"; do
    if [ -n "$reason" ]; then
      printf '%s # %s\n' "$(normalize_scope "$scope")" "$reason" >> "$lock"
    else
      printf '%s\n' "$(normalize_scope "$scope")" >> "$lock"
    fi
  done
}

active_scopes() {
  local lock="$1"
  [ -f "$lock" ] || return 0
  awk '
    /^[[:space:]]*$/ { next }
    /^[[:space:]]*#/ { next }
    {
      sub(/[[:space:]]+#.*$/, "")
      sub(/[[:space:]]+$/, "")
      sub(/^[[:space:]]+/, "")
      if ($0 != "") print $0
    }
  ' "$lock"
}

paths_overlap() {
  local left right
  left="$(normal_path "$1")"
  right="$(normal_path "$2")"
  [ "$left" = "$right" ] && return 0
  [[ "$left" == "$right"/* ]] && return 0
  [[ "$right" == "$left"/* ]] && return 0
  return 1
}

# Two scopes overlap if they're the same kind AND collide.
# - Path vs path: nested or equal (existing rule).
# - Task vs task: exact-match on the bracketed token.
# - Mixed kinds never overlap.
scopes_overlap() {
  local left="$1" right="$2"
  if is_task_lock "$left" && is_task_lock "$right"; then
    [ "$left" = "$right" ]
    return $?
  fi
  if is_task_lock "$left" || is_task_lock "$right"; then
    return 1
  fi
  paths_overlap "$left" "$right"
}

beads_scope() {
  local path
  path="$(normal_path "$1")"
  [ "$path" = "$workspace/.beads" ] && return 0
  [[ "$path" == "$workspace/.beads"/* ]] && return 0
  return 1
}

print_state() {
  local role lock
  for role in "${ROLES[@]}"; do
    lock="$(lock_path "$role")"
    printf -- '--- %s.lock ---\n' "$role"
    if [ -s "$lock" ]; then
      cat "$lock"
    else
      printf '%s\n' '(idle)'
    fi
  done
  printf '%s\n' '--- open beads ---'
  if [ -d "$workspace/.beads" ]; then
    (cd "$workspace" && bd --readonly list --status open --flat --no-pager --limit 20) \
      || printf '%s\n' 'BEADS open-task check failed.'
  else
    printf '%s\n' 'No BEADS database found.'
  fi
}

claim() {
  local role="$1"
  shift
  valid_role "$role" || { usage >&2; exit 64; }
  local scopes=()
  local reason=''
  while [ "$#" -gt 0 ]; do
    if [ "$1" = "--" ]; then
      shift
      reason="${*:-}"
      break
    fi
    scopes+=("$1")
    shift
  done
  if [ "${#scopes[@]}" -eq 0 ]; then
    usage >&2
    exit 64
  fi

  local scope
  for scope in "${scopes[@]}"; do
    if ! is_task_lock "$scope" && beads_scope "$scope"; then
      printf '%s\n' 'BEADS is shared coordination state and is never claimed.' >&2
      printf 'Remove %s from the claim; run bd commands directly,\n' "$(normal_path "$scope")" >&2
      printf 'or claim a specific bead with [bead-id] (e.g. '"'"'[primary-f99]'"'"').\n' >&2
      exit 64
    fi
  done

  write_lock "$role" "$reason" "${scopes[@]}"
  print_state

  local peer peer_lock peer_scope own_scope own_norm conflict=0
  while IFS= read -r peer; do
    peer_lock="$(lock_path "$peer")"
    while IFS= read -r peer_scope; do
      for own_scope in "${scopes[@]}"; do
        own_norm="$(normalize_scope "$own_scope")"
        if scopes_overlap "$own_norm" "$peer_scope"; then
          printf 'Conflict: %s overlaps %s (held by %s)\n' \
            "$own_norm" "$peer_scope" "$peer" >&2
          conflict=1
        fi
      done
    done < <(active_scopes "$peer_lock")
  done < <(peer_roles "$role")

  if [ "$conflict" -ne 0 ]; then
    write_lock "$role" ''
    printf '%s\n' 'Claim cleared because of overlap.'
    print_state
    exit 2
  fi
}

release() {
  local role="$1"
  valid_role "$role" || { usage >&2; exit 64; }
  write_lock "$role" ''
  print_state
}

case "${1:-}" in
  claim)
    shift
    [ "$#" -ge 2 ] || { usage >&2; exit 64; }
    claim "$@"
    ;;
  release)
    shift
    [ "$#" -eq 1 ] || { usage >&2; exit 64; }
    release "$1"
    ;;
  status)
    print_state
    ;;
  -h|--help|help|'')
    usage
    ;;
  *)
    usage >&2
    exit 64
    ;;
esac
