#!/usr/bin/env bash
# Shim — exec the orchestrate-cli Rust binary.
#
# The Rust port owns the claim / release / status flows; this script
# is the workspace-stable path agents reach for. First invocation
# triggers a release build if the binary is missing; subsequent
# invocations exec directly with no shell overhead.
#
# See orchestrate-cli/ for the source; the original shell helper lives
# in this repo's git history before this commit.

set -euo pipefail

workspace="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
binary="$workspace/orchestrate-cli/target/release/orchestrate"

if [ ! -x "$binary" ]; then
  (cd "$workspace/orchestrate-cli" && cargo build --release --bin orchestrate --quiet >&2)
fi

exec "$binary" "$@"
